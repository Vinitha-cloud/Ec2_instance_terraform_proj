# Terraform core directories

.terraform/
.terraform.lock.hcl

# Terraform state files (VERY IMPORTANT - contains sensitive data)

*.tfstate
*.tfstate.*

# Crash logs

crash.log
crash.*.log

# Sensitive variable files

*.tfvars
*.tfvars.json

# CLI configuration files

.terraformrc
terraform.rc

# Override files

override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan output files

*.tfplan

# macOS / system files

.DS_Store
